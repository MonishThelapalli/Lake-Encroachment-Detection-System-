import { useState, useRef, useEffect } from "react";
import { Button } from "@/components/ui/button";
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from "@/components/ui/card";
import { Label } from "@/components/ui/label";
import { Calendar } from "@/components/ui/calendar";
import { Popover, PopoverContent, PopoverTrigger } from "@/components/ui/popover";
import { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from "@/components/ui/select";
import { cn } from "@/lib/utils";
import { format } from "date-fns";
import { MapPin, CalendarIcon, Play, CheckCircle2, Upload, AlertCircle } from "lucide-react";
import { Alert, AlertDescription } from "@/components/ui/alert";
import Navbar from "@/components/Navbar";
import { GEEStatusBadge } from "@/components/GEEStatusBadge";
import { useToast } from "@/hooks/use-toast";
import { useNavigate } from "react-router-dom";
import { analyzeArea, AnalysisRequest, fetchPredefinedLakes, fetchLakeDetail, PredefinedLake } from "@/lib/api";
import { MapContainer, TileLayer, FeatureGroup, useMap } from "react-leaflet";
import { EditControl } from "react-leaflet-draw";
import { parseKMLFile } from "@/lib/kmlParser";
import "leaflet/dist/leaflet.css";
import "leaflet-draw/dist/leaflet.draw.css";

interface MapViewerProps {
  uploadedAOI: any;
  onAOIChange: (coords: number[][][]) => void;
  aoiSource: "draw" | "upload" | "predefined";
  setAoiSource: (source: "draw" | "upload" | "predefined") => void;
  setUploadedAOI: (aoi: any) => void;
  setSelectedLakeId: (id: string) => void;
}

const MapViewer = ({
  uploadedAOI,
  onAOIChange,
  aoiSource,
  setAoiSource,
  setUploadedAOI,
  setSelectedLakeId
}: MapViewerProps) => {
  const map = useMap();
  const featureGroupRef = useRef<any>(null);

  useEffect(() => {
    if (aoiSource !== "draw" && featureGroupRef.current) {
      featureGroupRef.current.clearLayers();
    }
  }, [aoiSource]);

  const _onCreated = (e: any) => {
    const layer = e.layer;
    if (featureGroupRef.current) {
      Object.keys(featureGroupRef.current._layers).forEach((layerId) => {
        if (layerId !== String(e.layer._leaflet_id)) {
          featureGroupRef.current.removeLayer(featureGroupRef.current._layers[layerId]);
        }
      });
    }
    const geojson = layer.toGeoJSON();
    const coords = geojson.geometry.coordinates;
    console.log("Drawn polygon:", coords);
    onAOIChange(coords);
    setAoiSource("draw");
    setUploadedAOI(null);
    setSelectedLakeId("");
  };

  const _onEdited = (e: any) => {
    if (featureGroupRef.current) {
      const layers = featureGroupRef.current.getLayers();
      if (layers.length > 0) {
        const geojson = layers[0].toGeoJSON();
        onAOIChange(geojson.geometry.coordinates);
      }
    }
  };

  const _onDeleted = (e: any) => {
    // Polygon deleted
  };

  return (
    <>
      <FeatureGroup ref={featureGroupRef}>
        <EditControl
          position="topright"
          onCreated={_onCreated}
          onEdited={_onEdited}
          onDeleted={_onDeleted}
          draw={{
            rectangle: false,
            circle: false,
            circlemarker: false,
            marker: false,
            polyline: false,
            polygon: {
              allowIntersection: false,
              drawError: {
                color: '#e1e100',
                message: '<strong>Oh snap!</strong> you can\'t draw that!'
              },
              shapeOptions: {
                color: '#97009c'
              }
            }
          }}
          edit={{
            edit: true,
            remove: true
          }}
        />
      </FeatureGroup>
    </>
  );
};

const Analysis = () => {
  const [startDate, setStartDate] = useState<Date>();
  const [endDate, setEndDate] = useState<Date>();
  const [isRunning, setIsRunning] = useState(false);
  const [geeAuthenticated, setGeeAuthenticated] = useState(false);
  const [geeChecking, setGeeChecking] = useState(true);
  const [aoiCoordinates, setAoiCoordinates] = useState<number[][][]>([[
    [74.2, 31.5], [74.3, 31.5], [74.3, 31.6], [74.2, 31.6], [74.2, 31.5]
  ]]);
  const [uploadedAOI, setUploadedAOI] = useState<any>(null);
  const [kmlError, setKmlError] = useState<string>("");
  const [kmlLoading, setKmlLoading] = useState(false);
  const [aoiSource, setAoiSource] = useState<"draw" | "upload" | "predefined">("draw");
  const fileInputRef = useRef<HTMLInputElement>(null);
  const [predefinedLakes, setPredefinedLakes] = useState<PredefinedLake[]>([]);
  const [selectedLakeId, setSelectedLakeId] = useState<string>("");
  const [lakeLoading, setLakeLoading] = useState(false);
  const { toast } = useToast();
  const navigate = useNavigate();

  useEffect(() => {
    const checkGEEStatus = async () => {
      try {
        const response = await fetch("http://localhost:8000/health");
        if (response.ok) {
          const data = await response.json();
          const isAuthenticated = data.gee_authenticated === true;
          setGeeAuthenticated(isAuthenticated);
        } else {
          setGeeAuthenticated(false);
        }
      } catch (err) {
        setGeeAuthenticated(false);
      } finally {
        setGeeChecking(false);
      }
    };
    checkGEEStatus();
    const interval = setInterval(checkGEEStatus, 30000);
    return () => clearInterval(interval);
  }, []);

  useEffect(() => {
    const loadLakes = async () => {
      try {
        const lakes = await fetchPredefinedLakes();
        setPredefinedLakes(lakes);
      } catch (error) {
        console.error("Failed to load predefined lakes:", error);
      }
    };
    loadLakes();
  }, []);

  const handleLakeSelection = async (lakeId: string) => {
    if (!lakeId) return;
    setLakeLoading(true);
    setSelectedLakeId(lakeId);
    try {
      const lakeDetail = await fetchLakeDetail(lakeId);
      setUploadedAOI(lakeDetail.geojson);
      setAoiSource("predefined");
      toast({
        title: "Lake Loaded",
        description: `${lakeDetail.name} (${lakeDetail.area_km2.toFixed(3)} km²) ready for analysis`
      });
    } catch (error) {
      toast({
        title: "Error",
        description: "Failed to load lake geometry",
        variant: "destructive"
      });
    } finally {
      setLakeLoading(false);
    }
  };

  const handleKMLFileChange = async (event: React.ChangeEvent<HTMLInputElement>) => {
    const file = event.target.files?.[0];
    if (!file) return;
    setKmlLoading(true);
    setKmlError("");
    try {
      const result = await parseKMLFile(file);
      if (!result.success) {
        setKmlError(result.error || "Failed to parse KML file");
        toast({
          title: "KML Parse Error",
          description: result.error,
          variant: "destructive"
        });
      } else {
        setUploadedAOI(result.geojson);
        setAoiSource("upload");
        toast({
          title: "KML Uploaded Successfully",
          description: result.message || "KML/KMZ file parsed and ready for analysis"
        });
        setKmlError("");
      }
    } catch (error) {
      const errorMsg = error instanceof Error ? error.message : "Unknown error";
      setKmlError(errorMsg);
      toast({
        title: "Error",
        description: errorMsg,
        variant: "destructive"
      });
    } finally {
      setKmlLoading(false);
      if (fileInputRef.current) {
        fileInputRef.current.value = "";
      }
    }
  };

  const getActiveAOI = () => {
    if (aoiSource === "upload" && uploadedAOI) {
      return uploadedAOI;
    }
    return {
      type: "Feature",
      geometry: { type: "Polygon", coordinates: aoiCoordinates },
      properties: { name: "User-drawn AOI" }
    };
  };

  const handleRunAnalysis = async () => {
    if (!startDate || !endDate) {
      toast({ title: "Missing Dates", description: "Please select start and end dates", variant: "destructive" });
      return;
    }
    if (startDate >= endDate) {
      toast({ title: "Invalid Date Range", description: "Start date must be before end date", variant: "destructive" });
      return;
    }
    if (aoiSource === "draw" && aoiCoordinates.length === 0) {
      toast({ title: "Missing AOI", description: "Please draw an AOI on the map", variant: "destructive" });
      return;
    }
    if (aoiSource === "upload" && !uploadedAOI) {
      toast({ title: "Missing AOI", description: "Please upload a KML/KMZ file", variant: "destructive" });
      return;
    }
    setIsRunning(true);
    const request: AnalysisRequest = {
      start_date: format(startDate, 'yyyy-MM-dd'),
      end_date: format(endDate, 'yyyy-MM-dd'),
      aoi: getActiveAOI()
    };
    try {
      const result = await analyzeArea(request);
      if (result.success) {
        toast({ title: "Analysis Complete", description: "Processing successful" });
        setTimeout(() => navigate("/reports", { state: { analysisResult: result } }), 1000);
      } else {
        toast({ title: "Analysis Failed", description: result.error, variant: "destructive" });
      }
    } catch (error) {
      toast({ title: "Error", description: `Failed: ${error instanceof Error ? error.message : 'Unknown'}`, variant: "destructive" });
    } finally {
      setIsRunning(false);
    }
  };

  return (
    <div className="min-h-screen bg-gradient-to-b from-background to-muted/30">
      <Navbar />
      <main className="container mx-auto px-4 py-8">
        <div className="max-w-5xl mx-auto space-y-8">
          <div>
            <h1 className="text-3xl font-bold mb-2">Configure Analysis</h1>
            <p className="text-muted-foreground">Set up your water body encroachment detection parameters</p>
          </div>

          <Card className={geeAuthenticated ? "border-green-200 bg-green-50" : "border-red-200 bg-red-50"}>
            <CardContent className="pt-6">
              <GEEStatusBadge />
            </CardContent>
          </Card>

          {!geeAuthenticated && (
            <Alert className="border-red-400 bg-red-100">
              <AlertCircle className="h-4 w-4 text-red-600" />
              <AlertDescription className="text-red-800 font-semibold">
                ⚠️ <strong>Analysis Disabled</strong> - Google Earth Engine is not authenticated.
                Please ensure GEE credentials are configured before running analysis.
                Live satellite data is required and mock data analysis is NOT permitted.
              </AlertDescription>
            </Alert>
          )}

          <Card>
            <CardHeader>
              <CardTitle className="flex items-center gap-2"><MapPin className="h-5 w-5 text-primary" />Define Area of Interest (AOI)</CardTitle>
              <CardDescription>Choose one method: draw on the map, use example lake, or upload KML/KMZ file</CardDescription>
            </CardHeader>
            <CardContent className="space-y-6">
              {uploadedAOI && (
                <Alert className="border-green-600 bg-green-50">
                  <CheckCircle2 className="h-4 w-4 text-green-600" />
                  <AlertDescription className="text-green-900">
                    <strong>{aoiSource === "predefined" ? "Predefined Lake Active" : "KML/KMZ AOI Active"}</strong> - {uploadedAOI.properties?.name || 'Uploaded AOI'}
                    <Button
                      variant="ghost"
                      size="sm"
                      onClick={() => {
                        setUploadedAOI(null);
                        setAoiSource("draw");
                        setSelectedLakeId("");
                        if (fileInputRef.current) fileInputRef.current.value = "";
                      }}
                      className="ml-2 h-6 px-2 text-xs text-green-700 hover:text-green-900"
                    >
                      Switch to Draw
                    </Button>
                  </AlertDescription>
                </Alert>
              )}

              <div className="space-y-2">
                <Label htmlFor="lake-selector">Quick Select: Predefined Lakes</Label>
                <Select
                  value={selectedLakeId}
                  onValueChange={handleLakeSelection}
                  disabled={lakeLoading}
                >
                  <SelectTrigger id="lake-selector" className="w-full">
                    <SelectValue placeholder="Choose a lake, draw on map, or upload KML" />
                  </SelectTrigger>
                  <SelectContent>
                    {predefinedLakes.map((lake) => (
                      <SelectItem key={lake.id} value={lake.id}>
                        {lake.name} ({lake.area_km2.toFixed(3)} km²)
                      </SelectItem>
                    ))}
                  </SelectContent>
                </Select>
                {lakeLoading && (
                  <p className="text-sm text-muted-foreground">Loading lake geometry...</p>
                )}
              </div>

              <div className="relative">
                <div className="absolute inset-0 flex items-center">
                  <span className="w-full border-t" />
                </div>
                <div className="relative flex justify-center text-xs uppercase">
                  <span className="bg-background px-2 text-muted-foreground">OR</span>
                </div>
              </div>

              <div className={cn("h-[400px] w-full rounded-md border overflow-hidden", uploadedAOI ? "opacity-50 pointer-events-none" : "" )}>
                <MapContainer center={[31.5, 74.3]} zoom={10} style={{ height: "100%", width: "100%" }}>
                  <TileLayer
                    url="https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png"
                    attribution='&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors'
                  />
                  <MapViewer
                    uploadedAOI={uploadedAOI}
                    onAOIChange={(coords) => {
                      if (!uploadedAOI) {
                        setAoiCoordinates(coords);
                        setAoiSource("draw");
                        toast({ title: "AOI Updated", description: `Selected ${coords[0].length} vertices` });
                      }
                    }}
                    aoiSource={aoiSource}
                    setAoiSource={setAoiSource}
                    setUploadedAOI={setUploadedAOI}
                    setSelectedLakeId={setSelectedLakeId}
                  />
                </MapContainer>
              </div>

              <div className="border-t pt-4 space-y-3">
                <Label className="text-base font-semibold">Or upload KML / KMZ file</Label>
                <div className="flex gap-2 items-end">
                  <input
                    ref={fileInputRef}
                    type="file"
                    accept=".kml,.kmz"
                    onChange={handleKMLFileChange}
                    className="hidden"
                  />
                  <Button
                    onClick={() => fileInputRef.current?.click()}
                    disabled={kmlLoading || !!uploadedAOI}
                    variant="outline"
                    className="gap-2"
                  >
                    <Upload className="h-4 w-4" />
                    {kmlLoading ? "Parsing..." : uploadedAOI ? "KML Loaded" : "Choose File"}
                  </Button>
                  <p className="text-sm text-muted-foreground">
                    Accepts .kml or .kmz (zipped KML)
                  </p>
                </div>

                {kmlError && (
                  <Alert variant="destructive">
                    <Alert Circle className="h-4 w-4" />
                    <AlertDescription>{kmlError}</AlertDescription>
                  </Alert>
                )}

                {uploadedAOI && !kmlError && (
                  <Alert className="border-green-200 bg-green-50">
                    <CheckCircle2 className="h-4 w-4 text-green-600" />
                    <AlertDescription className="text-green-900">
                      KML/KMZ file loaded successfully. The AOI will be displayed on the map.
                    </AlertDescription>
                  </Alert>
                )}
              </div>

              <Alert><CheckCircle2 className="h-4 w-4" /><AlertDescription>Your AOI will be analyzed against real satellite data from Google Earth Engine</AlertDescription></Alert>
            </CardContent>
          </Card>

          <Card>
            <CardHeader>
              <CardTitle className="flex items-center gap-2"><CalendarIcon className="h-5 w-5 text-primary" />Analysis Parameters</CardTitle>
              <CardDescription>Configure the time range for your analysis</CardDescription>
            </CardHeader>
            <CardContent className="space-y-6">
              <div className="space-y-4">
                <Label>Time Range</Label>
                <div className="grid grid-cols-2 gap-4">
                  <div className="space-y-2">
                    <Label className="text-sm text-muted-foreground">Start Date</Label>
                    <Popover>
                      <PopoverTrigger asChild>
                        <Button variant="outline" className={cn("w-full justify-start text-left font-normal", !startDate && "text-muted-foreground")}>
                          <Calendar Icon className="mr-2 h-4 w-4" />{startDate ? format(startDate, "PPP") : "Pick a date"}
                        </Button>
                      </PopoverTrigger>
                      <PopoverContent className="w-auto p-0">
                        <Calendar mode="single" selected={startDate} onSelect={setStartDate} initialFocus disabled={(date) => date > new Date()} />
                      </PopoverContent>
                    </Popover>
                  </div>
                  <div className="space-y-2">
                    <Label className="text-sm text-muted-foreground">End Date</Label>
                    <Popover>
                      <PopoverTrigger asChild>
                        <Button variant="outline" className={cn("w-full justify-start text-left font-normal", !endDate && "text-muted-foreground")}>
                          <CalendarIcon className="mr-2 h-4 w-4" />{endDate ? format(endDate, "PPP") : "Pick a date"}
                        </Button>
                      </PopoverTrigger>
                      <PopoverContent className="w-auto p-0">
                        <Calendar mode="single" selected={endDate} onSelect={setEndDate} initialFocus disabled={(date) => date > new Date()} />
                      </PopoverContent>
                    </Popover>
                  </div>
                </div>
              </div>
              <Alert><CheckCircle2 className="h-4 w-4 text-green-600" /><AlertDescription>Using Random Forest model with 99.00% accuracy trained on 1,000 ground truth samples</AlertDescription></Alert>
            </CardContent>
          </Card>

          <Card className="bg-gradient-to-br from-primary/5 via-accent/5 to-secondary/5">
            <CardContent className="p-6">
              <div className="flex items-center justify-between">
                <div><h3 className="font-semibold mb-1">Ready to Run Analysis?</h3><p className="text-sm text-muted-foreground">This will process your AOI with the selected parameters</p></div>
                <Button
                  size="lg"
                  onClick={handleRunAnalysis}
                  disabled={isRunning || !geeAuthenticated || geeChecking}
                  className="gap-2"
                  title={!geeAuthenticated ? "Live satellite data not available. Please verify GEE credentials." : ""}
                >
                  {isRunning ? (
                    <><div className="h-4 w-4 border-2 border-primary-foreground/30 border-t-primary-foreground rounded-full animate-spin" />Processing...</>
                  ) : !geeAuthenticated ? (
                    <>Analysis Disabled</>
                  ) : geeChecking ? (
                    <>Checking GEE...</>
                  ) : (
                    <><Play className="h-5 w-5" />Run Analysis</>
                  )}
                </Button>
              </div>
            </CardContent>
          </Card>
        </div>
      </main>
    </div>
  );
};

export default Analysis;
