# Water Watcher Environment Configuration

# Backend API Configuration
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_LOG_LEVEL=info

# Frontend Configuration
FRONTEND_HOST=localhost
FRONTEND_PORT=5173
VITE_API_URL=http://localhost:8000

# ML Model Configuration
MODEL_PATH=outputs/ground_truth_1000_model.pkl
ENCODER_PATH=outputs/ground_truth_1000_le.pkl
MODEL_ACCURACY=0.99

# Feature Extraction Configuration
USE_MOCK_DATA=true
GEE_CREDENTIALS_PATH=
SPATIAL_RESOLUTION=30  # meters, for Landsat

# Feature Validation
CONFIDENCE_THRESHOLD=0.7
NAN_THRESHOLD=0.05
FEATURE_RANGES_ENABLED=true

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=json
LOG_FILE=water_watcher.log

# CORS Configuration
CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000", "http://127.0.0.1:5173"]
CORS_CREDENTIALS=true
CORS_METHODS=["*"]
CORS_HEADERS=["*"]

# Database Configuration (for future use)
DATABASE_URL=
DATABASE_ECHO=false

# API Rate Limiting (for future use)
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=3600

# Security (for future use)
API_KEY_REQUIRED=false
JWT_SECRET=your-secret-key-here
ALLOWED_ORIGINS=*

# Performance
WORKER_PROCESSES=1
THREAD_POOL_SIZE=4
REQUEST_TIMEOUT=30
